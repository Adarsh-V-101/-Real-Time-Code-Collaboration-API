<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Coding Panel</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #494949;
      color: #9077ff;
    }
    .panel {
      max-width: 1100px;
      margin: 40px auto;
      padding: 20px;
      background: #5e5e5e;
      border-radius: 12px;
      box-shadow: 0 12px 28px rgba(0,0,0,0.08);
    }
    .panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 16px;
    }
    .panel-title {
      font-size: 1.4rem;
      font-weight: 700;
    }
    .editor-container {
      display: grid;
      grid-template-columns: 1fr 350px;
      gap: 18px;
    }
    .editor-box, .output-box {
      background: #1e1e2f;
      border-radius: 10px;
      padding: 16px;
      color: #f5f6fa;
    }
    .editor-box textarea {
      width: 100%;
      min-height: 420px;
      border: none;
      resize: vertical;
      background: #1e1e2f;
      color: #e7e7ff;
      font-family: Consolas, Monaco, 'Courier New', monospace;
      font-size: 0.95rem;
      line-height: 1.5;
      outline: none;
    }
    .output-box {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .output-box h2 {
      margin: 0;
      font-size: 1rem;
      color: #c1c7f0;
    }
    .output-display {
      flex: 1;
      background: #111122;
      border-radius: 8px;
      padding: 12px;
      overflow-y: auto;
      min-height: 420px;
      font-family: Consolas, Monaco, 'Courier New', monospace;
      font-size: 0.95rem;
      color: #dcdfe8;
      white-space: pre-wrap;
    }
    .actions {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      margin-top: 8px;
    }
    .actions button {
      padding: 10px 14px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      background: #4f6cff;
      color: #fff;
    }
  </style>
</head>
<body>
  <section class="panel">
    <div class="panel-header">
      <div>
        <div class="panel-title">Simple Coding Panel</div>
        <div>Write code on the left and preview output on the right.</div>
      </div>
      <div class="actions">
        <button id="runBtn" type="button">Run</button>
      </div>
    </div>

    <div class="editor-container">
      <div class="editor-box">
        <textarea id="codeEditor" spellcheck="false">// Type JavaScript here
console.log('Hello, world!');</textarea>
      </div>
      <div class="output-box">
        <h2>Console Output</h2>
        <div id="output" class="output-display">Press Run to execute the code.</div>
      </div>
    </div>
  </section>

  <script>
    const runBtn = document.getElementById('runBtn');
    const codeEditor = document.getElementById('codeEditor');
    const output = document.getElementById('output');
    const originalLog = console.log;

    runBtn.addEventListener('click', () => {
      output.textContent = '';
      try {
        const result = new Function(codeEditor.value)()s;
        console.log(result);
      } catch (error) {
        output.textContent = 'Error: ' + error.message;
      }
    });

    console.log = function(msg){
      const line = document.createElement('div');
      line.textContent = msg;
      output.appendChild(line);
      // originalLog.apply(console,arguments)
    }
  </script>
</body>
</html>
